<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= announcement.title %></title>

  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<a href="/">← На головну</a>

<div class="announcement-page">

  <div class="category">

    <% if (announcement.category === 'sale') { %>
      📦 Продаж
    <% } %>

    <% if (announcement.category === 'service') { %>
      🔧 Послуги
    <% } %>

    <% if (announcement.category === 'job') { %>
      💼 Робота
    <% } %>

    <% if (announcement.category === 'other') { %>
      📌 Інше
    <% } %>

  </div>

  <h1><%= announcement.title %></h1>

  <div class="meta">
    <p>
      <strong>Ціна:</strong>
      <%= announcement.price %> грн
    </p>

    <p>
      <strong>Опубліковано:</strong>
      <%= announcement.createdAt.toLocaleDateString('uk-UA') %>
    </p>
  </div>

  <div class="description">
    <h3>Опис</h3>

    <p>
      <%= announcement.description %>
    </p>
  </div>

  <div class="contacts">
    <h3>Контакти</h3>

    <p>
      <%= announcement.contactInfo %>
    </p>
  </div>

  <button
    id="delete-btn"
    class="delete-btn"
  >
    Видалити
  </button>

</div>

<script>
  const deleteBtn =
    document.querySelector('#delete-btn');

  const announcementId =
    <%= announcement.id %>;

  deleteBtn.addEventListener(
    'click',
    async () => {

      const confirmed = confirm(
        'Ви впевнені що хочете видалити це оголошення?'
      );

      if (!confirmed) {
        return;
      }

      try {

        const response =
          await fetch(
            `/announcements/${announcementId}`,
            {
              method: 'DELETE'
            }
          );

        if (response.ok) {
          window.location.href = '/';
        } else {
          alert('Помилка видалення');
        }

      } catch (error) {
        alert('Помилка видалення');
      }
    }
  );
</script>

</body>
</html>
