<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Дошка оголошень</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <div class="page-header">
      <h1>📋 Дошка оголошень</h1>
      <a href="/announcements" class="btn btn-primary">+ Додати оголошення</a>
    </div>

    <div class="toolbar">
      <form action="/" method="GET">
        <input type="hidden" name="sort" value="<%= sort %>">
        <input
          type="text"
          name="search"
          placeholder="Шукати оголошення..."
          value="<%= search %>"
        >
        <button type="submit" class="btn btn-secondary">Знайти</button>
      </form>

      <form action="/" method="GET" class="sort-form">
        <input type="hidden" name="search" value="<%= search %>">
        <label for="sort">Сортування:</label>
        <select name="sort" id="sort" onchange="this.form.submit()">
          <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Новіші спочатку</option>
          <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Старіші спочатку</option>
        </select>
      </form>
    </div>

    <% if (announcements.length === 0) { %>
      <div class="empty-state">
        <p>Оголошень не знайдено</p>
      </div>
    <% } else { %>
      <div class="cards">
        <% announcements.forEach(ann => { %>
          <div class="card">
            <div class="card-top">
              <h3 class="card-title"><%= ann.title %></h3>
              <span class="badge"><%= categoryLabel(ann.category) %></span>
            </div>
            <p class="card-description">
              <%= ann.description.length > 100 ? ann.description.substring(0, 100) + '...' : ann.description %>
            </p>
            <div class="card-meta">
              <span class="card-price"><%= ann.price %> грн</span>
              <span class="card-date"><%= formatDate(ann.createdAt) %></span>
              <a href="/announcements/<%= ann.id %>" class="card-link">Детальніше →</a>
            </div>
          </div>
        <% }) %>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage <= 1) { %>
            <span class="btn-disabled">Попередня</span>
          <% } else { %>
            <a href="/?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>">Попередня</a>
          <% } %>

          <% for (let p = 1; p <= totalPages; p++) { %>
            <a
              href="/?page=<%= p %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>"
              class="<%= p === currentPage ? 'active' : '' %>"
            ><%= p %></a>
          <% } %>

          <% if (currentPage >= totalPages) { %>
            <span class="btn-disabled">Наступна</span>
          <% } else { %>
            <a href="/?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>">Наступна</a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>
</body>
</html>
