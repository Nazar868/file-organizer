<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Дошка оголошень</title>

  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<header>
  <h1>📋 Дошка оголошень</h1>

  <a href="/announcements" class="btn">
    ➕ Додати оголошення
  </a>
</header>

<form class="search-form" method="GET">

  <input
    type="text"
    name="search"
    placeholder="Шукати оголошення..."
    value="<%= search %>"
  >

  <select name="sort">
    <option
      value="newest"
      <%= sort === 'newest' ? 'selected' : '' %>>
      Новіші спочатку
    </option>

    <option
      value="oldest"
      <%= sort === 'oldest' ? 'selected' : '' %>>
      Старіші спочатку
    </option>
  </select>

  <button type="submit">
    Знайти
  </button>

</form>

<% if (announcements.length === 0) { %>

  <div class="empty">
    Оголошень не знайдено
  </div>

<% } %>

<% announcements.forEach(ann => { %>

  <div class="card">

    <div class="category">

      <% if (ann.category === 'sale') { %>
        📦 Продаж
      <% } %>

      <% if (ann.category === 'service') { %>
        🔧 Послуги
      <% } %>

      <% if (ann.category === 'job') { %>
        💼 Робота
      <% } %>

      <% if (ann.category === 'other') { %>
        📌 Інше
      <% } %>

    </div>

    <h2>
      <%= ann.title %>
    </h2>

    <p>

      <%= ann.description.length > 100
        ? ann.description.substring(0, 100) + '...'
        : ann.description
      %>

    </p>

    <div class="meta">

      <span>
        💰 <%= ann.price %> грн
      </span>

      <span>
        📅
        <%= ann.createdAt.toLocaleDateString('uk-UA') %>
      </span>

    </div>

    <a
      href="/announcements/<%= ann.id %>"
      class="details-btn"
    >
      Детальніше
    </a>

  </div>

<% }) %>

<% if (totalPages > 1) { %>

<div class="pagination">

  <% if (currentPage > 1) { %>

    <a href="/?page=<%= currentPage - 1 %>&search=<%= search %>&sort=<%= sort %>">
      Попередня
    </a>

  <% } %>

  <% for(let i = 1; i <= totalPages; i++) { %>

    <% if(i === currentPage) { %>

      <span class="active-page">
        <%= i %>
      </span>

    <% } else { %>

      <a href="/?page=<%= i %>&search=<%= search %>&sort=<%= sort %>">
        <%= i %>
      </a>

    <% } %>

  <% } %>

  <% if(currentPage < totalPages) { %>

    <a href="/?page=<%= currentPage + 1 %>&search=<%= search %>&sort=<%= sort %>">
      Наступна
    </a>

  <% } %>

</div>

<% } %>

</body>
</html>
